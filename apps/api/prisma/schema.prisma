generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Academy {
  id        String   @id @default(uuid())
  name      String
  slug      String   @unique
  plan      Plan     @default(FREE)
  active    Boolean  @default(true)
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")
  users              User[]
  lessons            Lesson[]
  payments           Payment[]
  expenses           Expense[]
  fichaItems         FichaItem[]
  intakeAssessments  IntakeAssessment[]

  @@map("academies")
}

model User {
  id                 String         @id @default(uuid())
  academyId          String         @map("academy_id")
  name               String
  email              String         @unique
  password           String
  role               Role
  avatarUrl          String?        @map("avatar_url")
  active             Boolean        @default(true)
  createdAt          DateTime       @default(now()) @map("created_at")
  updatedAt          DateTime       @updatedAt @map("updated_at")
  evaluations        Evaluation[]      @relation("InstructorEvaluations")
  feedbacks          Feedback[]        @relation("InstructorFeedbacks")
  refreshTokens      RefreshToken[]
  instructorStudents Student[]         @relation("InstructorStudents")
  student            Student?
  academy            Academy           @relation(fields: [academyId], references: [id])
  instructorLessons  Lesson[]          @relation("InstructorLessons")
  instructorIntakes  IntakeAssessment[] @relation("InstructorIntakes")

  @@map("users")
}

model RefreshToken {
  id        String   @id @default(uuid())
  userId    String   @map("user_id")
  token     String   @unique
  expiresAt DateTime @map("expires_at")
  createdAt DateTime @default(now()) @map("created_at")
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("refresh_tokens")
}

model Student {
  id              String       @id @default(uuid())
  userId          String       @unique @map("user_id")
  instructorId    String       @map("instructor_id")
  currentSublevel String       @default("1A") @map("current_sublevel")
  intakeSublevel  String?      @map("intake_sublevel")
  intakeDate      DateTime?    @map("intake_date")
  styleTags       String[]     @map("style_tags")
  trainingDays    Int          @default(0) @map("training_days")
  currentStreak   Int          @default(0) @map("current_streak")
  maxStreak       Int          @default(0) @map("max_streak")
  createdAt       DateTime     @default(now()) @map("created_at")
  updatedAt       DateTime     @updatedAt @map("updated_at")
  checkins          Checkin[]
  evaluations       Evaluation[]
  feedbacks         Feedback[]
  instructor        User              @relation("InstructorStudents", fields: [instructorId], references: [id])
  user              User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  lessonStudents    LessonStudent[]
  payments          Payment[]
  intakeAssessments IntakeAssessment[]

  @@map("students")
}

model Sublevel {
  id          String       @id
  level       Int
  label       String
  description String
  order       Int
  criteria    Criterion[]
  evaluations Evaluation[]
  fichaItems  FichaItem[]

  @@map("sublevels")
}

model Criterion {
  id              String            @id @default(uuid())
  sublevelId      String            @map("sublevel_id")
  type            CriterionType
  category        CriterionCategory
  text            String
  context         String?
  minimumValue    Int?              @map("minimum_value")
  order           Int
  sublevel        Sublevel          @relation(fields: [sublevelId], references: [id])
  evaluationItems EvaluationItem[]

  @@map("criteria")
}

model Evaluation {
  id           String            @id @default(uuid())
  studentId    String            @map("student_id")
  instructorId String            @map("instructor_id")
  sublevelId   String            @map("sublevel_id")
  type         EvaluationType
  status       EvaluationStatus  @default(IN_PROGRESS)
  result       EvaluationResult?
  notes        String?
  evaluatedAt  DateTime          @default(now()) @map("evaluated_at")
  createdAt    DateTime          @default(now()) @map("created_at")
  updatedAt    DateTime          @updatedAt @map("updated_at")
  items        EvaluationItem[]
  instructor   User              @relation("InstructorEvaluations", fields: [instructorId], references: [id])
  student      Student           @relation(fields: [studentId], references: [id])
  sublevel     Sublevel          @relation(fields: [sublevelId], references: [id])

  @@map("evaluations")
}

model EvaluationItem {
  id            String         @id @default(uuid())
  evaluationId  String         @map("evaluation_id")
  criterionId   String         @map("criterion_id")
  state         CriterionState
  observedValue Int?           @map("observed_value")
  criterion     Criterion      @relation(fields: [criterionId], references: [id])
  evaluation    Evaluation     @relation(fields: [evaluationId], references: [id], onDelete: Cascade)

  @@unique([evaluationId, criterionId])
  @@map("evaluation_items")
}

model Checkin {
  id        String   @id @default(uuid())
  studentId String   @map("student_id")
  date      DateTime @db.Date
  createdAt DateTime @default(now()) @map("created_at")
  student   Student  @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@unique([studentId, date])
  @@map("checkins")
}

model Feedback {
  id           String    @id @default(uuid())
  studentId    String    @map("student_id")
  instructorId String    @map("instructor_id")
  text         String
  readAt       DateTime? @map("read_at")
  createdAt    DateTime  @default(now()) @map("created_at")
  instructor   User      @relation("InstructorFeedbacks", fields: [instructorId], references: [id])
  student      Student   @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@map("feedbacks")
}

enum Plan {
  FREE
  PRO
  ENTERPRISE
}

enum Role {
  ADMIN
  INSTRUCTOR
  STUDENT
}

enum CriterionType {
  BLOCKER
  COMPLEMENTARY
}

enum CriterionCategory {
  QUANTITATIVE
  OBSERVABLE
  CONTEXTUAL
}

enum CriterionState {
  MASTERED
  DEVELOPING
  NOT_STARTED
}

enum EvaluationType {
  REGULAR
  INTAKE
}

enum EvaluationStatus {
  IN_PROGRESS
  COMPLETED
}

enum EvaluationResult {
  ADVANCED
  MAINTAINED
  INTAKE_PLACED
}

enum LessonType {
  INDIVIDUAL
  GROUP
}

enum LessonStatus {
  CONFIRMED
  PENDING
  CANCELLED
}

model Lesson {
  id              String       @id @default(uuid())
  academyId       String       @map("academy_id")
  instructorId    String       @map("instructor_id")
  title           String
  type            LessonType
  date            DateTime     @db.Date
  time            String
  durationMinutes Int          @default(60) @map("duration_minutes")
  status          LessonStatus @default(PENDING)
  createdAt       DateTime     @default(now()) @map("created_at")

  academy    Academy         @relation(fields: [academyId], references: [id])
  instructor User            @relation("InstructorLessons", fields: [instructorId], references: [id])
  students   LessonStudent[]

  @@map("lessons")
}

enum PlanType {
  MENSALIDADE
  AVULSA
  PLANO_2X
  PLANO_3X
}

model Payment {
  id        String    @id @default(uuid())
  academyId String    @map("academy_id")
  studentId String    @map("student_id")
  plan      PlanType
  amount    Float
  month     Int
  year      Int
  paid      Boolean   @default(false)
  paidAt    DateTime? @map("paid_at")
  createdAt DateTime  @default(now()) @map("created_at")

  academy Academy @relation(fields: [academyId], references: [id])
  student Student @relation(fields: [studentId], references: [id])

  @@map("payments")
}

model Expense {
  id          String   @id @default(uuid())
  academyId   String   @map("academy_id")
  description String
  amount      Float
  month       Int
  year        Int
  createdAt   DateTime @default(now()) @map("created_at")

  academy Academy @relation(fields: [academyId], references: [id])

  @@map("expenses")
}

model LessonStudent {
  lessonId  String @map("lesson_id")
  studentId String @map("student_id")

  lesson  Lesson  @relation(fields: [lessonId], references: [id], onDelete: Cascade)
  student Student @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@id([lessonId, studentId])
  @@map("lesson_students")
}

model IntakeAssessment {
  id             String   @id @default(uuid())
  academyId      String   @map("academy_id")
  studentId      String   @map("student_id")
  instructorId   String   @map("instructor_id")
  resultSublevel String   @map("result_sublevel")
  triageData     Json     @map("triage_data")
  blockResults   Json     @map("block_results")
  focusNotes     String?  @map("focus_notes")
  createdAt      DateTime @default(now()) @map("created_at")

  academy    Academy @relation(fields: [academyId], references: [id])
  student    Student @relation(fields: [studentId], references: [id])
  instructor User    @relation("InstructorIntakes", fields: [instructorId], references: [id])

  @@map("intake_assessments")
}

enum FichaCategory {
  TECNICA
  DRILL_FIXACAO
  JOGO_TATICO
}

model FichaItem {
  id          String        @id @default(uuid())
  academyId   String        @map("academy_id")
  sublevelId  String        @map("sublevel_id")
  category    FichaCategory
  title       String
  description String?
  order       Int
  createdAt   DateTime      @default(now()) @map("created_at")
  updatedAt   DateTime      @updatedAt @map("updated_at")

  academy  Academy  @relation(fields: [academyId], references: [id])
  sublevel Sublevel @relation(fields: [sublevelId], references: [id])

  @@map("ficha_items")
}
